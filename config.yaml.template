# WorldClassicsJP 設定ファイル

# このファイルは config.yaml.template をコピーして config.yaml として使用してください
# cp config.yaml.template config.yaml

# ============================================================
# ローカルLLM設定（前処理・品質チェック用）
# ============================================================

# Ollama サーバーのホスト名
# ローカル実行の場合は "localhost" を使用
host: "localhost"

# Ollama サーバーのポート番号
# デフォルトは 11434
port: 11434

# 使用するLLMモデル名
# 例: llama3:8b, mistral:7b, gemma:7b
# 前処理と品質チェックで使用されます
model: "llama3:8b"

# ============================================================
# 翻訳量制限設定
# ============================================================

# 1日あたりの翻訳量上限（原文基準の文字数）
# SPEC §15 参照
# Phase 1: 12000文字/日（運用開始時）
# Phase 2: 24000文字/日（Phase 1 で2週間安定稼働後）
# Phase 3: 48000文字/日（Phase 2 で2週間安定稼働後）
daily_max_chars: 12000

# 現在の運用フェーズ（1, 2, 3 のいずれか）
# 1: 初期フェーズ（12,000文字/日）
# 2: 拡張フェーズ（24,000文字/日）
# 3: 最大フェーズ（48,000文字/日）
current_phase: 1

# ============================================================
# 備考
# ============================================================

# 1. ローカルLLM（Ollama）のセットアップ
#    - Ollama をインストール: https://ollama.ai/
#    - モデルをダウンロード: ollama pull llama3:8b
#    - サーバーを起動: ollama serve
#
# 2. フェーズ移行の判断
#    - 2週間以上、エラー率が 5% 未満で安定稼働していることを確認
#    - state.json の consecutive_fail_days が 0 を維持していることを確認
#    - RunLog でエラーパターンを分析
#    - 問題がなければ current_phase を増やし、daily_max_chars を更新
#
# 3. トラブルシューティング
#    - Ollama 接続エラー: ollama serve が起動しているか確認
#    - モデル不明エラー: ollama list でモデルがインストールされているか確認
#    - 翻訳量超過: daily_max_chars を一時的に減らす
